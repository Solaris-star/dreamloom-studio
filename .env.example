DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

CUSTOM_TEXT_API_KEY=
CUSTOM_TEXT_BASE_URL=https://api.openai.com
CUSTOM_TEXT_MODEL=
CUSTOM_TEXT_MODELS=
CUSTOM_TEXT_API_TYPE=openai

TONGYI_API_KEY=
GEMINI_API_KEY=

DOUBAO_IMAGE_API_KEY=
DOUBAO_IMAGE_BASE_URL=
DOUBAO_IMAGE_MODEL=

CUSTOM_IMAGE_API_KEY=
CUSTOM_IMAGE_BASE_URL=
CUSTOM_IMAGE_MODEL=
CUSTOM_IMAGE_MODELS=

MARKET_TREND_CACHE_TTL_MS=60000
MARKET_TREND_REQUEST_INTERVAL_MS=800
MARKET_TREND_RETRY_COUNT=0
MARKET_TREND_RETRY_DELAY_MS=500

NOVEL_BOOKS_DIR=
NOVEL_DOCKER_BOOKS_DIR=/app/books
WEB_PORT=5174
AGENT_TASK_WS_PORT=8787
AGENT_TASK_WS_PATH=/agent-tasks
AGENT_TASK_WS_ENABLED=true
AGENT_TASK_QUEUE_ENABLED=false
AGENT_TASK_QUEUE_NAME=novel-agent-writing
AGENT_TASK_QUEUE_CONCURRENCY=1
AGENT_TASK_QUEUE_ATTEMPTS=1
AGENT_TASK_QUEUE_BACKOFF_MS=3000
AGENT_TASK_QUEUE_JOB_TIMEOUT_MS=900000
AGENT_TASK_QUEUE_LOCK_DURATION_MS=300000
AGENT_TASK_QUEUE_DEFAULT_PROVIDER_CONCURRENCY=1
# 按 provider 覆盖：env:deepseek=2,env:custom-text=1
AGENT_TASK_QUEUE_PROVIDER_CONCURRENCY=
# 按 provider 超时毫秒：env:deepseek=600000
AGENT_TASK_QUEUE_PROVIDER_TIMEOUT_MS=
AGENT_TASK_QUEUE_REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Web auth (production / multi-instance)
# 未配置书架密码时默认拒绝自动登录；本地开发需显式开启：
NOVEL_ALLOW_OPEN_AUTH=false
# 仅在明确受信任的反向代理后开启，用于识别 HTTPS / 客户端 IP
NOVEL_TRUST_PROXY=false
# 默认在配置 REDIS_URL 时尝试使用 Redis 共享 Session；单机开发可设 false 强制内存
NOVEL_AUTH_REDIS=true
# 生产多实例建议 true：Redis 不可用时拒绝登录而不是静默回落内存
NOVEL_AUTH_REQUIRE_REDIS=false
NOVEL_AUTH_REDIS_CONNECT_TIMEOUT_MS=3000
# 强制按生产策略收紧认证（即使 NODE_ENV 不是 production）
NOVEL_AUTH_STRICT=false

# --- Production (docker-compose.prod.yml) ---
# Required for public deployments:
DREAMLOOM_DOMAIN=localhost
DREAMLOOM_IMAGE=dreamloom-studio:prod
HTTP_PORT=80
HTTPS_PORT=443
NOVEL_MAX_REQUEST_BODY_BYTES=16777216
# Bookshelf password / session secret — never commit real values
NOVEL_BOOKSHELF_PASSWORD=
NOVEL_AUTH_SECRET=
# Dev-only convenience; must stay false in public production
NOVEL_ALLOW_INSECURE_LOCAL_AUTH=false
