{
  "name": "dreamloom-studio",
  "version": "0.8.1",
  "description": "Dreamloom Studio (DLS), a local web writing studio for novel writers",
  "author": "Dreamloom Studio",
  "homepage": "https://github.com/Solaris-star/dreamloom-studio",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "vite preview --config vite.web.config.mjs",
    "dev": "vite --config vite.web.config.mjs",
    "build": "vite --config vite.web.config.mjs build",
    "test:unit": "node scripts/test-editor-save-queue.mjs && node scripts/test-editor-text-cleanup.mjs && node scripts/test-text-hint-decorations.mjs && node scripts/test-local-book-import-parser.mjs && node scripts/test-asset-reference-guards.mjs",
    "test:web": "node scripts/test-web-only-guards.mjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@lancedb/lancedb": "^0.31.0",
    "@tiptap/core": "^3.7.0",
    "@tiptap/extension-bold": "^3.7.0",
    "@tiptap/extension-highlight": "^3.7.0",
    "@tiptap/extension-italic": "^3.7.0",
    "@tiptap/extension-text-align": "^3.7.0",
    "@tiptap/starter-kit": "^3.7.0",
    "@tiptap/vue-3": "^3.7.0",
    "bullmq": "^5.79.2",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "element-plus": "^2.11.4",
    "gsap": "^3.15.0",
    "iconv-lite": "^0.6.3",
    "lucide-vue-next": "^0.561.0",
    "mammoth": "^1.12.0",
    "perfect-freehand": "^1.2.2",
    "pinia": "^3.0.3",
    "pngjs": "^7.0.0",
    "relation-graph-vue3": "^2.2.11",
    "roughjs": "^4.6.6",
    "sortablejs": "^1.15.6",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "^10.5.1",
    "prettier": "^3.6.2",
    "sass": "^1.93.2",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-vue-components": "^29.1.0",
    "vite": "^6.4.0",
    "vue": "^3.5.22"
  }
}
